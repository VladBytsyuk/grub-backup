#!/usr/bin/env bash
#
# grub-backup
# Simple utility for saving, restoring, listing, and deleting GRUB
# configuration backups, similar to git stash.
#
# Backed up files:
#   - /etc/default/grub
#   - /etc/grub.d/
#   - /boot/grub/grub.cfg
#
# restore automatically runs update-grub.
#
# Usage:
#   grub-backup save    [-p DIR] [-m MSG]
#   grub-backup restore [-p DIR] [-m MSG]
#   grub-backup list    [-p DIR]
#   grub-backup clear   [-p DIR] [-m MSG] [-a]
#

set -euo pipefail

BACKUP_ROOT="."
MESSAGE=""
ALL=false

UNNAMED="__unnamed__"

die() {
  echo "Error: $*" >&2
  exit 1
}

usage() {
  cat <<EOF
Usage:
  grub-backup save    [-p DIR] [-m MSG]
  grub-backup restore [-p DIR] [-m MSG]
  grub-backup list    [-p DIR]
  grub-backup clear   [-p DIR] [-m MSG] [-a]

Commands:
  save      Create a backup of the current GRUB configuration
  restore   Restore the latest matching backup
  list      Show available backups
  clear     Delete one or more backups

Options:
  -p, --path DIR       Directory for storing or reading backups
  -m, --message MSG    Backup name
  -a, --all            Delete all backups in the directory
  -h, --help           Show this help
EOF
}

require_root() {
  # Modifying GRUB files requires root privileges.
  if [[ "${EUID}" -ne 0 ]]; then
    die "this command requires root privileges. Run it with sudo."
  fi
}

safe_message() {
  # Convert unsafe characters to "_".
  local msg="${1:-$UNNAMED}"

  # Bash pattern substitution replaces everything except letters, digits,
  # dots, underscores, and hyphens.
  msg="${msg//[^a-zA-Z0-9._-]/_}"

  echo "$msg"
}

backup_dir() {
  echo "$BACKUP_ROOT/.grub-backup"
}

find_latest_backup() {
  local msg_safe
  msg_safe="$(safe_message "$MESSAGE")"

  find "$(backup_dir)" \
    -maxdepth 1 \
    -type f \
    -name "grub-backup-*-${msg_safe}.tar.gz" \
    | sort \
    | tail -n 1
}

cmd_save() {
  require_root

  local dir msg_safe timestamp archive meta
  dir="$(backup_dir)"
  msg_safe="$(safe_message "$MESSAGE")"
  timestamp="$(date '+%Y%m%d-%H%M%S')"
  archive="$dir/grub-backup-${timestamp}-${msg_safe}.tar.gz"
  meta="$(mktemp)"

  mkdir -p "$dir"

  # The manifest makes backup lists easier to inspect.
  cat > "$meta" <<EOF
created_at=$timestamp
message=${MESSAGE:-}
hostname=$(hostname)
EOF

  tar -czf "$archive" \
    -C / \
    etc/default/grub \
    etc/grub.d \
    boot/grub/grub.cfg \
    -C "$(dirname "$meta")" "$(basename "$meta")"

  rm -f "$meta"

  echo "Backup created: $archive"
}

cmd_restore() {
  require_root

  local archive
  archive="$(find_latest_backup)"

  [[ -n "$archive" ]] || die "backup not found"

  echo "Restoring from: $archive"

  # Extract only GRUB system files.
  tar -xzf "$archive" -C / \
    etc/default/grub \
    etc/grub.d \
    boot/grub/grub.cfg

  # Regenerate grub.cfg from the restored configuration.
  update-grub

  echo "GRUB restored."
}

cmd_list() {
  local dir
  dir="$(backup_dir)"

  [[ -d "$dir" ]] || {
    echo "No backups found."
    return
  }

  find "$dir" -maxdepth 1 -type f -name 'grub-backup-*.tar.gz' | sort | while read -r file; do
    basename "$file"
  done
}

cmd_clear() {
  local dir msg_safe files
  dir="$(backup_dir)"

  [[ -d "$dir" ]] || {
    echo "No backups found."
    return
  }

  if [[ "$ALL" == true ]]; then
    files="$(find "$dir" -maxdepth 1 -type f -name 'grub-backup-*.tar.gz')"
  else
    msg_safe="$(safe_message "$MESSAGE")"
    files="$(find "$dir" -maxdepth 1 -type f -name "grub-backup-*-${msg_safe}.tar.gz")"
  fi

  [[ -n "$files" ]] || {
    echo "Nothing to delete."
    return
  }

  echo "$files" | xargs rm -f
  echo "Backups deleted."
}

COMMAND="${1:-}"
[[ -n "$COMMAND" ]] || {
  usage
  exit 1
}
shift

while [[ $# -gt 0 ]]; do
  case "$1" in
    -p|--path)
      BACKUP_ROOT="${2:-}"
      [[ -n "$BACKUP_ROOT" ]] || die "missing path after $1"
      shift 2
      ;;
    -m|--message)
      MESSAGE="${2:-}"
      [[ -n "$MESSAGE" ]] || die "missing name after $1"
      shift 2
      ;;
    -a|--all)
      ALL=true
      shift
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      die "unknown option: $1"
      ;;
  esac
done

case "$COMMAND" in
  save)
    cmd_save
    ;;
  restore)
    cmd_restore
    ;;
  list)
    cmd_list
    ;;
  clear)
    cmd_clear
    ;;
  -h|--help)
    usage
    ;;
  *)
    die "unknown command: $COMMAND"
    ;;
esac
