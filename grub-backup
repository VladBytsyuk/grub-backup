#!/usr/bin/env bash
#
# grub-backup
# Simple utility for saving, restoring, listing, and deleting GRUB
# configuration backups, similar to git stash.
#
# Backed up files:
#   - /etc/default/grub
#   - /etc/grub.d/
#   - /boot/grub/grub.cfg
#
# restore automatically runs update-grub.
#
# Usage:
#   grub-backup save    [-p DIR] [-m MSG]
#   grub-backup restore [-p DIR] [-m MSG]
#   grub-backup list    [-p DIR]
#   grub-backup clear   [-p DIR] [-m MSG] [-a]
#
# restore without -m restores the latest unnamed backup.
# clear -m deletes all backups with that name.
#

set -euo pipefail

BACKUP_ROOT="."
MESSAGE=""
ALL=false

UNNAMED="__unnamed__"

die() {
  echo "Error: $*" >&2
  exit 1
}

usage() {
  cat <<EOF
Usage:
  grub-backup save    [-p DIR] [-m MSG]
  grub-backup restore [-p DIR] [-m MSG]
  grub-backup list    [-p DIR]
  grub-backup clear   [-p DIR] [-m MSG] [-a]

Commands:
  save      Create a backup of the current GRUB configuration
  restore   Restore the latest matching backup; without -m, restore latest unnamed backup
  list      Show available backups
  clear     Delete backups; with -m, delete all backups with that name

Options:
  -p, --path DIR       Directory for storing or reading backups
  -m, --message MSG    Backup name
  -a, --all            Delete all backups in the directory
  -h, --help           Show this help
EOF
}

require_root() {
  # Modifying GRUB files requires root privileges.
  if [[ "${EUID}" -ne 0 ]]; then
    die "this command requires root privileges. Run it with sudo."
  fi
}

safe_message() {
  # Convert unsafe characters to "_".
  local msg="${1:-$UNNAMED}"

  # Bash pattern substitution replaces everything except letters, digits,
  # dots, underscores, and hyphens.
  msg="${msg//[^a-zA-Z0-9._-]/_}"

  echo "$msg"
}

backup_dir() {
  echo "$BACKUP_ROOT/.grub-backup"
}

archive_contains() {
  local archive="$1"
  local path="$2"

  tar -tzf "$archive" | grep -Fx -- "$path" >/dev/null
}

find_latest_backup() {
  local dir msg_safe
  dir="$(backup_dir)"
  [[ -d "$dir" ]] || return 0

  msg_safe="$(safe_message "$MESSAGE")"

  find "$dir" \
    -maxdepth 1 \
    -type f \
    -name "grub-backup-*-${msg_safe}.tar.gz" \
    | sort \
    | tail -n 1
}

cmd_save() {
  require_root

  local dir msg_safe timestamp archive tmpdir meta
  dir="$(backup_dir)"
  msg_safe="$(safe_message "$MESSAGE")"
  timestamp="$(date '+%Y%m%d-%H%M%S')"
  archive="$dir/grub-backup-${timestamp}-${msg_safe}.tar.gz"
  tmpdir="$(mktemp -d)"
  meta="$tmpdir/manifest"
  trap 'rm -rf "$tmpdir"; trap - RETURN' RETURN

  mkdir -p "$dir"

  # The manifest makes backup lists easier to inspect.
  cat > "$meta" <<EOF
created_at=$timestamp
message=${MESSAGE:-}
hostname=$(hostname)
EOF

  tar -czf "$archive" \
    -C / \
    etc/default/grub \
    etc/grub.d \
    boot/grub/grub.cfg \
    -C "$(dirname "$meta")" "$(basename "$meta")"

  echo "Backup created: $archive"
}

cmd_restore() {
  require_root

  local archive staging
  archive="$(find_latest_backup)"

  [[ -n "$archive" ]] || die "backup not found"

  echo "Restoring from: $archive"

  archive_contains "$archive" 'etc/default/grub' \
    || die "backup is missing etc/default/grub"
  archive_contains "$archive" 'etc/grub.d/' \
    || archive_contains "$archive" 'etc/grub.d' \
    || die "backup is missing etc/grub.d"
  archive_contains "$archive" 'boot/grub/grub.cfg' \
    || die "backup is missing boot/grub/grub.cfg"

  staging="$(mktemp -d)"
  trap 'rm -rf "$staging"; trap - RETURN' RETURN

  # Stage first so system files are touched only after archive validation.
  tar -xzf "$archive" -C "$staging" \
    etc/default/grub \
    etc/grub.d \
    boot/grub/grub.cfg

  mkdir -p /etc/default /boot/grub
  cp -a "$staging/etc/default/grub" /etc/default/grub
  rm -rf /etc/grub.d
  cp -a "$staging/etc/grub.d" /etc/grub.d
  cp -a "$staging/boot/grub/grub.cfg" /boot/grub/grub.cfg

  # Regenerate grub.cfg from the restored configuration.
  update-grub

  echo "GRUB restored."
}

cmd_list() {
  local dir
  dir="$(backup_dir)"

  [[ -d "$dir" ]] || {
    echo "No backups found."
    return
  }

  find "$dir" -maxdepth 1 -type f -name 'grub-backup-*.tar.gz' | sort | while read -r file; do
    basename "$file"
  done
}

cmd_clear() {
  local dir msg_safe find_args
  dir="$(backup_dir)"

  [[ -d "$dir" ]] || {
    echo "No backups found."
    return
  }

  if [[ "$ALL" == true ]]; then
    find_args=(-name 'grub-backup-*.tar.gz')
  else
    msg_safe="$(safe_message "$MESSAGE")"
    find_args=(-name "grub-backup-*-${msg_safe}.tar.gz")
  fi

  if ! find "$dir" -maxdepth 1 -type f "${find_args[@]}" -print -quit | grep -q .; then
    echo "Nothing to delete."
    return
  fi

  find "$dir" -maxdepth 1 -type f "${find_args[@]}" -print0 | xargs -0 rm -f
  echo "Backups deleted."
}

COMMAND="${1:-}"
[[ -n "$COMMAND" ]] || {
  usage
  exit 1
}
shift

while [[ $# -gt 0 ]]; do
  case "$1" in
    -p|--path)
      BACKUP_ROOT="${2:-}"
      [[ -n "$BACKUP_ROOT" ]] || die "missing path after $1"
      shift 2
      ;;
    -m|--message)
      MESSAGE="${2:-}"
      [[ -n "$MESSAGE" ]] || die "missing name after $1"
      shift 2
      ;;
    -a|--all)
      ALL=true
      shift
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      die "unknown option: $1"
      ;;
  esac
done

case "$COMMAND" in
  save)
    cmd_save
    ;;
  restore)
    cmd_restore
    ;;
  list)
    cmd_list
    ;;
  clear)
    cmd_clear
    ;;
  -h|--help)
    usage
    ;;
  *)
    die "unknown command: $COMMAND"
    ;;
esac
